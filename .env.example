# ──────────────────────────────────────────────────────────────────────────────
# ReBrewie Control Pi – environment configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# All variables are optional – defaults shown below are used when a variable
# is absent from .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── Transport ─────────────────────────────────────────────────────────────────
# Which protocol to use to reach the Brewie machine.
#   mock   – built-in simulator (no real machine needed; great for UI dev)
#   tcp    – direct TCP to the stock tty_tcp_bridge.py on the Brewie Pi
#   serial – USB/serial connection (requires pyserial)
#   http   – HTTP bridge (experimental)
BREWIE_TRANSPORT=tcp

# ── TCP settings (used when BREWIE_TRANSPORT=tcp) ────────────────────────────
# IP address of the Brewie machine on your local network.
BREWIE_HOST=192.168.1.132

# TCP port that tty_tcp_bridge.py is listening on (stock default: 9000).
BREWIE_PORT=9000

# Stock Brewie tty_tcp_bridge.py expects framed binary packets, not raw P-lines.
# Leave this enabled for port 9000. Disable only for a custom line-oriented shim.
BREWIE_TCP_FRAMING=true

# ── Serial settings (used when BREWIE_TRANSPORT=serial) ──────────────────────
BREWIE_SERIAL_PORT=/dev/ttyUSB0
BREWIE_SERIAL_BAUD=115200

# ── HTTP bridge settings (used when BREWIE_TRANSPORT=http) ───────────────────
BREWIE_HTTP_BASE=http://192.168.1.113:8080

# ── Web server ────────────────────────────────────────────────────────────────
# Address and port this Pi app listens on.  0.0.0.0 makes it reachable from
# any device on your local network (typical LAN usage).
LOCAL_BIND=0.0.0.0
LOCAL_PORT=8080

# ── Recipes ───────────────────────────────────────────────────────────────────
# Directory where recipe JSON files are stored (relative to the project root).
RECIPE_DIR=recipes

# ── Machine discovery ─────────────────────────────────────────────────────────
DISCOVERY_ENABLED=true
# Subnet prefix to scan (last octet is swept 1–254).
DISCOVERY_SUBNET=192.168.1
# Per-host connection timeout in seconds during a scan.
DISCOVERY_TIMEOUT=3.0

# ── P80 session parameters ────────────────────────────────────────────────────
# These are sent with every P80 command (init and heartbeat).
#
# Batch volume in litres fed into the P80 init command.
# Match this to your typical batch size.
TO_LITER=20.0

# Temperature offset applied to mash setpoints (positive = run hotter).
# Compensates for a sensor that reads low, for example.
MASH_TEMP_DELTA=0.0

# Temperature offset applied to boil setpoints.
BOIL_TEMP_DELTA=0.0

# ── Blink camera feed ─────────────────────────────────────────────────────────
# Optional Progress page snapshot panel. Blink cloud snapshots are refreshed no
# faster than once every 60 seconds.
BLINK_ENABLED=false
BLINK_USERNAME=
BLINK_PASSWORD=
# Optional exact camera name from the Blink app. Leave blank to use the first camera.
BLINK_CAMERA_NAME=
BLINK_REFRESH_SECONDS=60
